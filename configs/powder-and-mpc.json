{
    "components": ["fat", "protein", "lactose"],
    "quantities": { "powder": 1 },
    "compositions": {
        "milk": { "fat": 0.03, "protein": 0.03, "lactose": 0.03 },
        "skim": { "fat": 0.0001 },
        "cream": { "fat": 0.42 },
        "evaporated milk": { "total-solids": 0.50 },
        "powder": { "fat": 0.015, "protein": 0.34, "total-solids": 0.95 },
        "MPC": { "protein": 0.8, "total-solids": 0.95},
        "pm18": { "total-solids": 0.18 },
        "butter": { "fat": 0.8 },
        "buttermilk": { "fat": 0.0001 }
    },
    "operations": [
        {
            "operation": "separation",
            "input": "milk",
            "outputs": ["skim", "cream"],
            "separation-component": "fat"
        },
        {
            "operation": "split",
            "input": "skim",
            "outputs": ["powder skim", "mpc skim"]
        },
        {
            "operation": "split",
            "input": "cream",
            "outputs": ["powder cream", "butter cream"]
        },
        {
            "operation": "filter",
            "input": "mpc skim",
            "outputs": ["retentate", "permeate"],
            "retention-coefficients": { "protein": 0.95, "fat": 0.95 }
        },
        {
            "operation": "dry",
            "input": "permeate",
            "output": "pm18"
        },
        {
            "operation": "mix",
            "inputs": ["powder skim", "powder cream", "pm18"],
            "outputs": ["treated milk"]
        },
        {
            "operation": "dry",
            "inputs": ["treated milk"],
            "outputs": ["evaporated milk"]
        },
        {
            "operation": "dry",
            "inputs": ["evaporated milk"],
            "outputs": ["powder"]
        },
        {
            "operation": "dry",
            "input": "retentate",
            "output": "MPC"
        },
        {
            "operation": "separation",
            "input": "butter cream",
            "outputs": ["buttermilk", "butter"],
            "separation-component": "fat"
        }
    ]
}
