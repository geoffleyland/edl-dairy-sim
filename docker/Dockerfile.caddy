# Stage 1: build the frontend.
# Node is a build-time tool only — it does not appear in the final image.
FROM node:20-alpine AS frontend-builder

WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

# Stage 2: Caddy serves the built frontend and proxies /api/* to Julia.
FROM caddy:2-alpine

COPY --from=frontend-builder /app/dist /srv
COPY docker/Caddyfile /etc/caddy/Caddyfile
