{
    "_comment": "Site configuration. All rates in kg/hr, volumes and levels in kg. Silo IDs match stream IDs — one silo per stream, same name.",

    "site_name": "Example Dairy",

    "streams": [
        { "id": "milk",                 "name": "Raw Milk",             "role": "input"        },
        { "id": "skim",                 "name": "Skim Milk",            "role": "intermediate" },
        { "id": "cream",                "name": "Cream",                "role": "intermediate" },
        { "id": "buttermilk",           "name": "Buttermilk",           "role": "intermediate" },
        { "id": "butter",               "name": "Butter",               "role": "output"       },
        { "id": "condensed-skim",       "name": "Condensed Skim",       "role": "intermediate" },
        { "id": "condensed-buttermilk", "name": "Condensed Buttermilk", "role": "intermediate" },
        { "id": "smp",                  "name": "SMP",                  "role": "output"       },
        { "id": "bmp",                  "name": "BMP",                  "role": "output"       }
    ],

    "machines": [
        {
            "id":        "separator",
            "name":      "Separator",
            "type":      "separator",
            "resources": ["separator"],
            "modes": [
                {
                    "id":               "running",
                    "label":            "Run",
                    "operation":        "separate-milk",
                    "rate_kg_per_hour": 120000
                }
            ]
        },
        {
            "id":        "butter-plant",
            "name":      "Butter Plant",
            "type":      "butter-plant",
            "resources": ["butter-plant"],
            "modes": [
                {
                    "id":               "running",
                    "label":            "Run",
                    "operation":        "separate-cream",
                    "rate_kg_per_hour": 15000
                }
            ]
        },
        {
            "id":               "condenser",
            "name":             "Condenser",
            "type":             "condenser",
            "resources":        ["condenser"],
            "changeover_hours": 1.0,
            "max_run_hours":    20.0,
            "clean_hours":      4.0,
            "modes": [
                {
                    "id":               "skim",
                    "label":            "Skim",
                    "operation":        "condense-skim",
                    "rate_kg_per_hour": 150000
                },
                {
                    "id":               "buttermilk",
                    "label":            "BM",
                    "operation":        "condense-bm",
                    "rate_kg_per_hour": 150000
                }
            ]
        },
        {
            "id":               "drier",
            "name":             "Drier",
            "type":             "drier",
            "resources":        ["drier"],
            "changeover_hours": 1.0,
            "max_run_hours":    16.0,
            "clean_hours":      6.0,
            "modes": [
                {
                    "id":               "smp",
                    "label":            "SMP",
                    "operation":        "dry-skim",
                    "rate_kg_per_hour": 35000
                },
                {
                    "id":               "bmp",
                    "label":            "BMP",
                    "operation":        "dry-bm",
                    "rate_kg_per_hour": 30000
                }
            ]
        }
    ],

    "silos": [
        { "id": "milk",                 "name": "Raw Milk",             "volume_kg": 200000, "initial_kg": 80000 },
        { "id": "skim",                 "name": "Skim",                 "volume_kg": 100000, "initial_kg": 0     },
        { "id": "cream",                "name": "Cream",                "volume_kg":  50000, "initial_kg": 0     },
        { "id": "buttermilk",           "name": "Buttermilk",           "volume_kg":  50000, "initial_kg": 0     },
        { "id": "condensed-skim",       "name": "Condensed Skim",       "volume_kg":  30000, "initial_kg": 0     },
        { "id": "condensed-buttermilk", "name": "Condensed Buttermilk", "volume_kg":  20000, "initial_kg": 0     }
    ],

    "process": {
        "_comment": "Yield.jl mass-balance config. Yield.jl reads components/compositions/quantities/operations and ignores the rest. Operation IDs are used by the simulation to look up stream graphs; Yield.jl ignores them. inputs/outputs are arrays throughout.",

        "components": ["fat", "protein", "lactose"],

        "quantities": {
            "milk": 1.0
        },

        "compositions": {
            "milk":                 { "fat": 0.043, "protein": 0.034, "lactose": 0.049 },
            "skim":                 { "fat": 0.001 },
            "cream":                { "fat": 0.400 },
            "buttermilk":           { "fat": 0.005 },
            "butter":               { "fat": 0.820 },
            "condensed-skim":       { "total-solids": 0.450 },
            "condensed-buttermilk": { "total-solids": 0.400 },
            "smp":                  { "total-solids": 0.960 },
            "bmp":                  { "total-solids": 0.960 }
        },

        "operations": [
            {
                "id":                   "separate-milk",
                "name":                 "Separator",
                "operation":            "separation",
                "inputs":               ["milk"],
                "outputs":              ["skim", "cream"],
                "separation-component": "fat"
            },
            {
                "id":                   "separate-cream",
                "name":                 "Butter Plant",
                "operation":            "separation",
                "inputs":               ["cream"],
                "outputs":              ["butter", "buttermilk"],
                "separation-component": "fat"
            },
            {
                "id":        "condense-skim",
                "name":      "Condenser",
                "operation": "dry",
                "inputs":    ["skim"],
                "outputs":   ["condensed-skim"]
            },
            {
                "id":        "condense-bm",
                "name":      "Condenser (BM)",
                "operation": "dry",
                "inputs":    ["buttermilk"],
                "outputs":   ["condensed-buttermilk"]
            },
            {
                "id":        "dry-skim",
                "name":      "Drier",
                "operation": "dry",
                "inputs":    ["condensed-skim"],
                "outputs":   ["smp"]
            },
            {
                "id":        "dry-bm",
                "name":      "Drier (BM)",
                "operation": "dry",
                "inputs":    ["condensed-buttermilk"],
                "outputs":   ["bmp"]
            }
        ]
    }
}
